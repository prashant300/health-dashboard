rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Your private report data — only you can read/write
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == "yadav.prashant300@gmail.com";
    }

    // Claude snapshot — publicly readable (no auth), only you can write
    match /claude_snapshot/health_data {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "yadav.prashant300@gmail.com";
    }
  }
}
